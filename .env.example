# ------------------------------------------------------------------
# Faksimale ClosedLoop AI Dashboard — environment variables
# Copy this file to `.env.local` and fill in values for your environment.
# ------------------------------------------------------------------

# External 3D simulation engine REST base URL.
# Leave empty to use the built-in mock (good for local dev).
# Example: https://simulation.internal.faksimale.id
SIMULATION_API_URL=

# Bearer token sent as Authorization header to the simulation API. Optional.
SIMULATION_API_TOKEN=

# Request timeout (ms) for external simulation calls. Default 5000.
SIMULATION_API_TIMEOUT_MS=5000
